# Video Gate Configuration
# Change these values before deploying!

ADMIN_PASSWORD=changeme
SECRET_KEY=replace-this-with-a-long-random-string

# Logo displayed on the gate page (what your members see)
# Use a URL to an image, or put your logo in the static/ folder
# and use /static/logo.png
# Leave empty for no logo.
LOGO_URL=/static/logo.jpg
